---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import { Image } from "astro:assets";
import partenaire1 from "../assets/img/partenaire-1.avif";
import partenaire2 from "../assets/img/partenaire-2.avif";
import partenaire3 from "../assets/img/partenaire-3.avif";
import partenaire4 from "../assets/img/partenaire-4.avif";
---

<Layout title="Accueil - Echos Sonores">
    <Hero />

    <div class="mx-75">
        <section
            class="section--wrapper bg-noirbleunuit px-(--spacing-4xl) py-(--spacing-4xl)"
        >
            <header>
                <h2 class="section__title u-sr-only">
                    Informations principales du festival
                </h2>
            </header>

            <article
                class="bg-linear-to-t from-[rgba(12,30,91,0.98)] to-noirbleunuit rounded-lg p-(--spacing-4xl) max-w-[30rem];
            width: calc(100% + 2 * var(--spacing-4xl) - 2 * var(--spacing-xl));
            margin-left: calc(var(--spacing-xl) - var(--spacing-4xl));
            margin-right: calc(var(--spacing-xl) - var(--spacing-4xl))"
                data-aos="zoom-in"
            >
                <h3 class="text-base font-bold mb-(--spacing-3xl)">
                    28 au 31 octobre 2026
                </h3>
                <ul class="flex flex-col gap-(--spacing-base) u-list-unstyled">
                    <li
                        class="flex items-start gap-(--spacing-base) text-sm leading-[1.4]"
                    >
                        <span class="info-card__icon" aria-hidden="true"
                            >🕓</span
                        >
                        <span>
                            <strong>Ouverture des portes :</strong>
                            16h00
                        </span>
                    </li>
                    <li
                        class="flex items-start gap-(--spacing-base) text-sm leading-[1.4]"
                    >
                        <span class="info-card__icon" aria-hidden="true"
                            >🎵</span
                        >
                        <span>
                            <strong>Concerts :</strong>
                            jusqu'à 0h30
                        </span>
                    </li>
                    <li
                        class="flex items-start gap-(--spacing-base) text-sm leading-[1.4]"
                    >
                        <span class="info-card__icon" aria-hidden="true"
                            >📍</span
                        >
                        <span>
                            <strong>Lieu :</strong>
                            Site en plein air – Audincourt (25)
                        </span>
                    </li>
                    <li
                        class="flex items-start gap-(--spacing-base) text-sm leading-[1.4]"
                    >
                        <span class="info-card__icon" aria-hidden="true"
                            >👥</span
                        >
                        <span>
                            <strong>Capacité :</strong>
                            jusqu'à 3 000 personnes / jour
                        </span>
                    </li>
                </ul>
            </article>
        </section>

        <section class="section--wrapper mt-(--spacing-4xl)">
            <header>
                <h2 class="u-sr-only">Explorer le festival</h2>
            </header>

            <ul class="u-list-unstyled grid grid-cols-2 gap-(--spacing-2xl)">
                <li class="nav-card" data-aos="zoom-in-up">
                    <div class="nav-card__content">
                        <p class="nav-card__icon" aria-hidden="true">🎪</p>
                        <h3 class="nav-card__title">Le Festival</h3>
                        <p class="nav-card__text">
                            Un événement à taille humaine ancré dans l'écologie,
                            la convivialité et la créativité.
                        </p>
                    </div>
                    <a class="nav-card__btn btn btn--ghost" href="/aboutus">
                        Découvrir
                    </a>
                </li>

                <li class="nav-card" data-aos="zoom-in-up">
                    <div class="nav-card__content">
                        <p class="nav-card__icon" aria-hidden="true">🎶</p>
                        <h3 class="nav-card__title">Programme</h3>
                        <p class="nav-card__text">
                            Découvrez les artistes programmés chaque jour :
                            roots, dub, reggae fusion, world music.
                        </p>
                    </div>
                    <a class="nav-card__btn btn btn--ghost" href="/programme/">
                        Découvrir
                    </a>
                </li>

                <li class="nav-card" data-aos="zoom-in-up">
                    <div class="nav-card__content">
                        <p class="nav-card__icon" aria-hidden="true">🌟</p>
                        <h3 class="nav-card__title">Artistes</h3>
                        <p class="nav-card__text">
                            Accédez à la liste complète des artistes invités et
                            émergents.
                        </p>
                    </div>
                    <a class="nav-card__btn btn btn--ghost" href="/artistes/">
                        Découvrir
                    </a>
                </li>

                <li class="nav-card" data-aos="zoom-in-up">
                    <div class="nav-card__content">
                        <p class="nav-card__icon" aria-hidden="true">📌</p>
                        <h3 class="nav-card__title">Infos pratiques</h3>
                        <p class="nav-card__text">
                            Transports, hébergements, tarifs et accessibilité
                            pour préparer votre venue.
                        </p>
                    </div>
                    <a
                        class="nav-card__btn btn btn--ghost"
                        href="/infospratiques"
                    >
                        Découvrir
                    </a>
                </li>
            </ul>
        </section>

        <section
            class="section--wrapper bg-noirbleunuit px-(--spacing-4xl) py-(--spacing-4xl) text-blanc text-center"
        >
            <header>
                <h2 class="section__title">Nos valeurs</h2>
            </header>

            <ul class="flex flex-col gap-(--spacing-base) u-list-unstyled">
                <li class="values__item">
                    <p>
                        <strong>Écologique</strong> – “festival responsable”
                    </p>
                </li>
                <li class="values__item">
                    <p>
                        <strong>Convivial &amp; inclusif</strong> – “une grande famille”
                    </p>
                </li>
                <li class="values__item">
                    <p>
                        <strong>Créatif &amp; surprenant</strong> – “programmation
                        audacieuse”
                    </p>
                </li>
            </ul>
        </section>

        <section
            class="section--wrapper bg-noirbleunuit px-(--spacing-4xl) py-(--spacing-4xl) text-blanc"
        >
            <header>
                <h2 class="section__title text-center">Nos Partenaires</h2>
            </header>

            <div class="grid grid-cols-4 gap-(--spacing-3xl)">
                <div
                    class="bg-blanc rounded-sm overflow-hidden aspect-square flex items-center justify-center"
                    data-aos="zoom-in-down"
                    data-aos-duration="3000"
                >
                    <Image
                        src={partenaire1}
                        alt="Partenaire 1"
                        class="partners__logo"
                    />
                </div>
                <div
                    class="bg-blanc rounded-sm overflow-hidden aspect-square flex items-center justify-center"
                    data-aos="zoom-in-down"
                    data-aos-duration="2500"
                >
                    <Image
                        src={partenaire2}
                        alt="Partenaire 2"
                        class="partners__logo"
                    />
                </div>
                <div
                    class="bg-blanc rounded-sm overflow-hidden aspect-square flex items-center justify-center"
                    data-aos="zoom-in-down"
                    data-aos-duration="1000"
                >
                    <Image
                        src={partenaire3}
                        alt="Partenaire 3"
                        class="partners__logo"
                    />
                </div>
                <div
                    class="bg-blanc rounded-sm overflow-hidden aspect-square flex items-center justify-center"
                    data-aos="zoom-in-down"
                    data-aos-duration="500"
                >
                    <Image
                        src={partenaire4}
                        alt="Partenaire 4"
                        class="partners__logo"
                    />
                </div>
            </div>
        </section>
    </div>
</Layout>
